# Remote providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional alternative OpenAI-compatible providers
OPENROUTER_API_KEY=

# Local providers usually do not need API keys.
# LM Studio default local API: http://127.0.0.1:1234/v1
# Ollama default local API: http://127.0.0.1:11434/api

# Example if your LM Studio server is protected by a token:
LM_STUDIO_API_KEY=

# Example if your Ollama setup is behind a gateway that expects a token:
OLLAMA_API_KEY=
